meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{dev}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "admin1234@gmail.com",
    "password": "11223344"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("token", res.body.data.access_token);
    bru.setVar("refreshToken", res.body.data.refresh_token);
  }
}
