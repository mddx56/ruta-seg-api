  token: {{token}}
}

body:json {
  {
    "items": [
      {
        "imei": "123456789012345",
        "cod_sim": "89591111111111111111",
        "sim_phone_number": "70000001",
        "sim_provider": "Tigo"
      }
    ]
  }
}
